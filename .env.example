# ─────────────────────────────────────────────
# 环境变量配置模板
# 复制为 .env 后填入实际值：
#   cp .env.example .env
# ─────────────────────────────────────────────

# ══════════════════════════════════════════════
# TTS 语音合成（播客音频）
# ══════════════════════════════════════════════

# -- Provider 选择 --
# 可选值: edge-tts (默认/免费), openai, minimax, mimo
TTS_PROVIDER=edge-tts

# -- 音色配置 --
# edge-tts: 男声 zh-CN-YunxiNeural (默认), zh-CN-YunjianNeural
#           女声 zh-CN-XiaoxiaoNeural (默认), zh-CN-XiaoyiNeural
TTS_MALE_VOICE=
TTS_FEMALE_VOICE=

# -- OpenAI TTS（需 API Key）--
# 音色: alloy / echo / fable / onyx / nova / shimmer
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TTS_MODEL=tts-1

# -- MiniMax TTS（需 API Key）--
MINIMAX_API_KEY=

# -- MiMo TTS --
# 两种计费方式，选一种：
#   Token Plan（推荐，tp- 前缀）：https://mimo.mi.com → Token Plan → Console
#   Pay-as-you-go（sk- 前缀）：https://mimo.mi.com → API Keys
MIMO_API_KEY=

# 音色：冰糖（女）/ 茉莉（女）/ 苏打（女）/ 白桦（男）/ Mia（女）/ Chloe（女）/ Milo（男）/ Dean（男）/ mimo_default
MIMO_TTS_VOICE=苏打

# 播客专用音色配置（覆盖默认音色）
MIMO_TTS_MALE_VOICE=Dean       # 男主播音色
MIMO_TTS_FEMALE_VOICE=苏打     # 女主播音色

# 风格指令（自然语言，MiMo TTS 独有）
MIMO_TTS_STYLE=新闻播报风格，语速适中，沉稳大气

# ── MiMo 可选：覆盖 Base URL（一般不需要）──
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# ══════════════════════════════════════════════
# 代理配置（访问被墙的源）
# ══════════════════════════════════════════════

# 在 config.local.mjs 中配置，不在此处
