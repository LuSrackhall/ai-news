# ══════════════════════════════════════════════════════════════════════
# MiMo TTS 配置模板
# API Key 池 + 自定义音色设计
# ══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# 共用配置（所有 TTS 场景共享）
# ─────────────────────────────────────────────────────────────────────

# API Key 池（多个 Key 用逗号分隔，自动轮换防限流）
# 获取方式：https://mimo.mi.com → Token Plan → Console
MIMO_API_KEY_POOL=tp-key1,tp-key2,tp-key3

# API Endpoint（根据 Key 前缀自动选择，也可手动指定）
# 中国集群：https://token-plan-cn.xiaomimimo.com/v1
# 新加坡集群：https://token-plan-sgp.xiaomimimo.com/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# ══════════════════════════════════════════════════════════════════════
# 播客音频配置（PODCAST_ 前缀）
# ══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# TTS 模型选择
# ─────────────────────────────────────────────────────────────────────
# 可选值：
#   mimo-v2.5-tts               - 使用预设音色（冰糖/茉莉/苏打/白桦等）
#   mimo-v2.5-tts-voicedesign   - 自定义音色设计（推荐，可创造独特音色）
PODCAST_MIMO_TTS_MODEL=mimo-v2.5-tts-voicedesign

# ─────────────────────────────────────────────────────────────────────
# 模式1：预设音色（当 MODEL=mimo-v2.5-tts 时使用）
# ─────────────────────────────────────────────────────────────────────
# 可用音色：
#   女声：冰糖（温柔）/ 茉莉（清新）/ 苏打（沉稳）/ Mia（英文）/ Chloe（英文）
#   男声：白桦（稳重）/ Milo（英文）/ Dean（英文）
#   默认：mimo_default

# 默认音色（未指定 speaker 时使用）
PODCAST_MIMO_TTS_VOICE=冰糖

# 男主播音色
PODCAST_MIMO_TTS_MALE_VOICE=白桦

# 女主播音色
PODCAST_MIMO_TTS_FEMALE_VOICE=冰糖

# ─────────────────────────────────────────────────────────────────────
# 模式2：自定义音色设计（当 MODEL=mimo-v2.5-tts-voicedesign 时使用）
# ─────────────────────────────────────────────────────────────────────
# 用自然语言描述音色特征，MiMo 会为你"创造"一个全新音色
# 描述要素：年龄、性别、音色特点、语速、风格、情感等

# 女主播音色描述
# 示例：
#   - 温柔知性：一个28岁的知性女性，声音温柔如水，清澈悦耳，像春风拂面般舒适
#   - 甜美活力：一个24岁的年轻女性，声音甜美清脆，充满活力，像银铃般悦耳动听
#   - 优雅成熟：一个35岁的优雅女性，声音沉稳大气，温润如玉，像播音员般专业悦耳
#   - 快节奏：一个28岁的知性女性，声音温柔清澈，语速较快，节奏紧凑，像专业播音员一样干脆利落
PODCAST_MIMO_TTS_FEMALE_VOICE_DESC=一个28岁的知性女性，声音温柔清澈，语速较快，节奏紧凑，像专业播音员一样干脆利落

# 男主播音色描述
# 示例：
#   - 磁性暖男：一个30岁的男性，声音温润磁性，低沉有魅力，像大提琴般醇厚动听
#   - 阳光少年：一个22岁的年轻男性，声音清朗阳光，充满朝气，像邻家男孩般亲切
#   - 沉稳大叔：一个40岁的成熟男性，声音浑厚有力，沉稳大气，像新闻主播般专业
#   - 快节奏：一个30岁的男性，声音温润磁性，语速较快，节奏明快，像新闻主播一样专业高效
PODCAST_MIMO_TTS_MALE_VOICE_DESC=一个30岁的男性，声音温润磁性，语速较快，节奏明快，像新闻主播一样专业高效

# ─────────────────────────────────────────────────────────────────────
# 风格指令（可选，两种模式通用）
# ─────────────────────────────────────────────────────────────────────
# 自然语言描述播报风格，留空则不添加风格指令
# 示例：
#   - 新闻播报风格，语速适中，沉稳大气
#   - 播客风格，语速适中，亲民自然
#   - 轻松聊天风格，亲切友好
#   - 专业讲解风格，清晰有力
# PODCAST_MIMO_TTS_STYLE=播客风格，语速适中，亲民

# ══════════════════════════════════════════════════════════════════════
# 视频生成配置（VIDEO_ 前缀）
# ══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# TTS 模型选择
# ─────────────────────────────────────────────────────────────────────
# 可选值：
#   mimo-v2.5-tts               - 使用预设音色
#   mimo-v2.5-tts-voicedesign   - 自定义音色设计
VIDEO_MIMO_TTS_MODEL=mimo-v2.5-tts

# ─────────────────────────────────────────────────────────────────────
# 预设音色配置（当 MODEL=mimo-v2.5-tts 时使用）
# ─────────────────────────────────────────────────────────────────────
VIDEO_MIMO_TTS_VOICE=冰糖

# ─────────────────────────────────────────────────────────────────────
# 自定义音色设计（当 MODEL=mimo-v2.5-tts-voicedesign 时使用）
# ─────────────────────────────────────────────────────────────────────
# 取消注释并填写描述即可启用

# 音色描述
# VIDEO_MIMO_TTS_VOICE_DESC=一个专业的产品讲解员，声音清晰有力，富有感染力，语速适中

# 风格指令（可选）
# VIDEO_MIMO_TTS_STYLE=专业讲解风格，清晰流畅，富有感染力

# ══════════════════════════════════════════════════════════════════════
# 配置示例
# ══════════════════════════════════════════════════════════════════════
#
# 【示例1】标准播报（预设音色）
# ─────────────────────────────────────────────────────────────────────
# PODCAST_MIMO_TTS_MODEL=mimo-v2.5-tts
# PODCAST_MIMO_TTS_MALE_VOICE=白桦
# PODCAST_MIMO_TTS_FEMALE_VOICE=冰糖
# PODCAST_MIMO_TTS_STYLE=新闻播报风格，语速适中，沉稳大气
#
# 【示例2】天籁之音（自定义设计）
# ─────────────────────────────────────────────────────────────────────
# PODCAST_MIMO_TTS_MODEL=mimo-v2.5-tts-voicedesign
# PODCAST_MIMO_TTS_FEMALE_VOICE_DESC=一个28岁的知性女性，声音温柔如水，清澈悦耳，像春风拂面般舒适
# PODCAST_MIMO_TTS_MALE_VOICE_DESC=一个30岁的男性，声音温润磁性，低沉有魅力，像大提琴般醇厚动听
#
# 【示例3】快节奏播客（自定义设计）
# ─────────────────────────────────────────────────────────────────────
# PODCAST_MIMO_TTS_MODEL=mimo-v2.5-tts-voicedesign
# PODCAST_MIMO_TTS_FEMALE_VOICE_DESC=一个28岁的知性女性，声音温柔清澈，语速较快，节奏紧凑，像专业播音员一样干脆利落
# PODCAST_MIMO_TTS_MALE_VOICE_DESC=一个30岁的男性，声音温润磁性，语速较快，节奏明快，像新闻主播一样专业高效
#
# 【示例4】Key 池防限流
# ─────────────────────────────────────────────────────────────────────
# MIMO_API_KEY_POOL=tp-key1,tp-key2,tp-key3,tp-key4
#
